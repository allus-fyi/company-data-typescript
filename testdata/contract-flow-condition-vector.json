{
  "cases": [
    { "name": "null_is_true", "condition": null, "answers": {}, "expect": true },
    { "name": "eq_string", "condition": {"field":"type","op":"eq","value":"business"},
      "answers": {"type":"business"}, "expect": true },
    { "name": "eq_string_miss", "condition": {"field":"type","op":"eq","value":"business"},
      "answers": {"type":"private"}, "expect": false },
    { "name": "eq_unanswered", "condition": {"field":"type","op":"eq","value":"business"},
      "answers": {}, "expect": false },
    { "name": "ne", "condition": {"field":"type","op":"ne","value":"private"},
      "answers": {"type":"business"}, "expect": true },
    { "name": "gt_number", "condition": {"field":"employees","op":"gt","value":10},
      "answers": {"employees":11}, "expect": true },
    { "name": "gt_number_string_coerce", "condition": {"field":"employees","op":"gt","value":10},
      "answers": {"employees":"11"}, "expect": true },
    { "name": "le_equal", "condition": {"field":"employees","op":"le","value":10},
      "answers": {"employees":10}, "expect": true },
    { "name": "gt_mixed_is_false", "condition": {"field":"employees","op":"gt","value":10},
      "answers": {"employees":"abc"}, "expect": false },
    { "name": "date_gt_true", "condition": {"field":"start_date","op":"gt","value":"2025-01-01"},
      "answers": {"start_date":"2026-06-01"}, "expect": true },
    { "name": "date_lt_true", "condition": {"field":"start_date","op":"lt","value":"2026-12-31"},
      "answers": {"start_date":"2026-06-01"}, "expect": true },
    { "name": "date_ge_equal_true", "condition": {"field":"start_date","op":"ge","value":"2026-06-01"},
      "answers": {"start_date":"2026-06-01"}, "expect": true },
    { "name": "date_gt_earlier_false", "condition": {"field":"start_date","op":"gt","value":"2026-06-01"},
      "answers": {"start_date":"2025-01-01"}, "expect": false },
    { "name": "string_gt_true", "condition": {"field":"grade","op":"gt","value":"a"},
      "answers": {"grade":"b"}, "expect": true },
    { "name": "eq_bool_true", "condition": {"field":"has_vat","op":"eq","value":true},
      "answers": {"has_vat":true}, "expect": true },
    { "name": "in", "condition": {"field":"type","op":"in","value":["a","b","business"]},
      "answers": {"type":"business"}, "expect": true },
    { "name": "nin", "condition": {"field":"type","op":"nin","value":["a","b"]},
      "answers": {"type":"business"}, "expect": true },
    { "name": "answered_true", "condition": {"field":"vat_no","op":"answered"},
      "answers": {"vat_no":"NL01"}, "expect": true },
    { "name": "answered_false_empty_string", "condition": {"field":"vat_no","op":"answered"},
      "answers": {"vat_no":""}, "expect": false },
    { "name": "answered_false_missing", "condition": {"field":"vat_no","op":"answered"},
      "answers": {}, "expect": false },
    { "name": "empty_true_missing", "condition": {"field":"vat_no","op":"empty"},
      "answers": {}, "expect": true },
    { "name": "empty_false", "condition": {"field":"vat_no","op":"empty"},
      "answers": {"vat_no":"x"}, "expect": false },
    { "name": "and", "condition": {"op":"and","children":[
        {"field":"type","op":"eq","value":"business"},
        {"op":"or","children":[
          {"field":"employees","op":"gt","value":10},
          {"field":"has_vat","op":"eq","value":true}]}]},
      "answers": {"type":"business","employees":3,"has_vat":true}, "expect": true },
    { "name": "and_short", "condition": {"op":"and","children":[
        {"field":"type","op":"eq","value":"business"},
        {"field":"employees","op":"gt","value":10}]},
      "answers": {"type":"private","employees":99}, "expect": false },
    { "name": "not", "condition": {"op":"not","children":[
        {"field":"type","op":"eq","value":"private"}]},
      "answers": {"type":"business"}, "expect": true },
    { "name": "empty_children_and_true", "condition": {"op":"and","children":[]},
      "answers": {}, "expect": true },
    { "name": "empty_children_or_false", "condition": {"op":"or","children":[]},
      "answers": {}, "expect": false }
  ]
}
